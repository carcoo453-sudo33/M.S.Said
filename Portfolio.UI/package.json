{
  "name": "portfolio.ui",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:prod": "node node_modules/@angular/cli/bin/ng build --configuration production",
    "build:publish": "ng build --configuration=publish",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:watch": "ng test --watch",
    "test:coverage": "ng test --code-coverage --watch=false --browsers=ChromeHeadless",
    "test:ci": "ng test --watch=false --browsers=ChromeHeadless --code-coverage",
    "test:chrome": "ng test --browsers=Chrome",
    "test:firefox": "ng test --browsers=Firefox",
    "test:edge": "ng test --browsers=Edge",
    "e2e": "cypress run",
    "e2e:open": "cypress open",
    "lint": "ng lint",
    "lint:fix": "ng lint --fix",
    "lint:styles": "stylelint \"src/**/*.css\" \"src/**/*.scss\"",
    "format": "prettier --write \"src/**/*.{ts,html,css,scss,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,html,css,scss,json}\"",
    "type-check": "tsc --noEmit",
    "deploy:check": "node deploy-check.js",
    "check:build": "node check-build.js",
    "analyze": "node analyze-bundle.js",
    "lighthouse": "node lighthouse-audit.js",
    "lighthouse:ci": "lhci autorun",
    "perf:audit": "npm run build:prod && npm run lighthouse",
    "perf:analyze": "npm run analyze && npm run lighthouse",
    "optimize": "npm run build:prod && npm run analyze",
    "serve:ci": "http-server dist/portfolio-ui -p 4200 -s",
    "test:a11y": "pa11y-ci --sitemap http://localhost:4200/sitemap.xml",
    "test:a11y:axe": "axe http://localhost:4200 --exit",
    "security:audit": "npm audit --audit-level=moderate",
    "security:fix": "npm audit fix",
    "test:all": "npm run lint && npm run type-check && npm run test:ci && npm run e2e",
    "ci:test": "npm run test:all && npm run test:a11y && npm run lighthouse:ci"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@10.9.2",
  "dependencies": {
    "@angular/common": "21.2.1",
    "@angular/compiler": "21.2.1",
    "@angular/core": "21.2.1",
    "@angular/forms": "21.2.1",
    "@angular/platform-browser": "21.2.1",
    "@angular/router": "21.2.1",
    "@microsoft/signalr": "^10.0.0",
    "@ngx-translate/core": "^17.0.0",
    "@ngx-translate/http-loader": "^17.0.0",
    "@spartan-ng/ui-core": "^0.0.1-alpha.380",
    "dompurify": "^3.0.8",
    "lucide-angular": "^0.575.0",
    "ng-lazyload-image": "^9.1.3",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.1.4",
    "@angular-eslint/builder": "^18.4.1",
    "@angular-eslint/eslint-plugin": "^18.4.1",
    "@angular-eslint/eslint-plugin-template": "^18.4.1",
    "@angular-eslint/schematics": "^18.4.1",
    "@angular-eslint/template-parser": "^18.4.1",
    "@angular/build": "21.2.1",
    "@angular/cli": "^21.2.1",
    "@angular/compiler-cli": "21.2.1",
    "@axe-core/cli": "^4.10.2",
    "@lhci/cli": "^0.14.0",
    "@typescript-eslint/eslint-plugin": "^8.18.1",
    "@typescript-eslint/parser": "^8.18.1",
    "autoprefixer": "^10.4.24",
    "cypress": "^13.15.2",
    "eslint": "^9.17.0",
    "http-server": "^14.1.1",
    "jsdom": "^27.1.0",
    "lighthouse": "^12.0.0",
    "pa11y-ci": "^3.1.0",
    "postcss": "^8.5.6",
    "prettier": "^3.4.2",
    "source-map-explorer": "^2.5.3",
    "stylelint": "^16.12.0",
    "stylelint-config-standard": "^36.0.1",
    "tailwindcss": "^3.4.13",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8",
    "webpack-bundle-analyzer": "^4.10.1"
  }
}
