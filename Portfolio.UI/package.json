{
  "name": "portfolio.ui",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:prod": "node node_modules/@angular/cli/bin/ng build --configuration production",
    "build:publish": "ng build --configuration=publish",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "deploy:check": "node deploy-check.js",
    "check:build": "node check-build.js",
    "analyze": "node analyze-bundle.js",
    "lighthouse": "node lighthouse-audit.js",
    "perf:audit": "npm run build:prod && npm run lighthouse",
    "perf:analyze": "npm run analyze && npm run lighthouse",
    "optimize": "npm run build:prod && npm run analyze"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@10.9.2",
  "dependencies": {
    "@angular/common": "^21.1.0",
    "@angular/compiler": "^21.1.0",
    "@angular/core": "^21.1.0",
    "@angular/forms": "^21.1.0",
    "@angular/platform-browser": "^21.1.0",
    "@angular/router": "^21.2.1",
    "@microsoft/signalr": "^8.0.7",
    "@ngx-translate/core": "^17.0.0",
    "@ngx-translate/http-loader": "^17.0.0",
    "@spartan-ng/ui-core": "^0.0.1-alpha.380",
    "lucide-angular": "^0.575.0",
    "ng-lazyload-image": "^9.1.3",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.1.4",
    "@angular/cli": "^21.1.4",
    "@angular/compiler-cli": "^21.1.0",
    "autoprefixer": "^10.4.24",
    "jsdom": "^27.1.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.13",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8",
    "webpack-bundle-analyzer": "^4.10.1",
    "source-map-explorer": "^2.5.3",
    "lighthouse": "^12.0.0",
    "@angular-devkit/build-angular": "^21.1.4"
  }
}
