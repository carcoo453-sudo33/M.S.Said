{
  "ConnectionStrings": {
    "DefaultConnection": "#{ConnectionString}#"
  },
  "Jwt": {
    "Issuer": "#{JwtIssuer}#",
    "Audience": "#{JwtAudience}#",
    "SecretKey": "#{JwtSecretKey}#",
    "ExpiryInMinutes": 60
  },
  "EmailSettings": {
    "SmtpHost": "smtp.gmail.com",
    "SmtpPort": "587",
    "SmtpUsername": "#{SmtpUsername}#",
    "SmtpPassword": "#{SmtpPassword}#",
    "FromEmail": "#{FromEmail}#",
    "ToEmail": "#{ToEmail}#",
    "EnableSsl": "true"
  },
  "GitHub": {
    "Token": "#{GitHubToken}#"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}